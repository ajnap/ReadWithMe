# Read With Me — environment variables
# Copy this file to `.env.local` and fill in real values. `.env.local` is gitignored.
# Nothing here is required to run the marketing site today; these are placeholders
# for the commerce / character-builder integration. See docs/INTEGRATION.md.

# --- Shopify Storefront API (client-safe; used to build a cart from the browser) ---
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=

# --- Shopify Admin API (SERVER ONLY — never expose to the browser / no NEXT_PUBLIC_ prefix) ---
# SHOPIFY_ADMIN_API_TOKEN=

# --- Optional: analytics, etc. ---
# NEXT_PUBLIC_ANALYTICS_ID=
